@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix tst: <https://w3id.org/axone/ontology/test/> .
@prefix schema: <http://schema.org/> .
@prefix assertion: <https://w3id.org/axone/ontology/v$major/schema/core/assertion/> .

tst:AssertionCredentialClassShape a sh:NodeShape ;
  sh:targetNode assertion:AssertionCredential ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdfs:Class ;
    sh:minCount 1 ;
    sh:message "AssertionCredential must be defined as an rdfs:Class."@en ;
  ] ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:message "AssertionCredential must have at least one rdfs:label."@en ;
  ] ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:message "AssertionCredential must have at least one rdfs:comment describing its purpose."@en ;
  ] .

tst:AssertionCredentialUriPropertyShape a sh:NodeShape ;
  sh:targetNode assertion:predicate, assertion:scope, assertion:subject, assertion:supportingEvidence ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdf:Property ;
    sh:minCount 1 ;
    sh:message "Assertion URI properties must be defined as rdf:Property."@en ;
  ] ;
  sh:property [
    sh:path schema:domainIncludes ;
    sh:hasValue assertion:AssertionCredential ;
    sh:minCount 1 ;
    sh:message "Assertion URI properties must have AssertionCredential in schema:domainIncludes."@en ;
  ] ;
  sh:property [
    sh:path schema:rangeIncludes ;
    sh:hasValue xsd:anyURI ;
    sh:minCount 1 ;
    sh:message "Assertion URI properties must have xsd:anyURI in schema:rangeIncludes."@en ;
  ] .

tst:AssertionCredentialObjectPropertyShape a sh:NodeShape ;
  sh:targetNode assertion:object ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdf:Property ;
    sh:minCount 1 ;
    sh:message "Assertion object must be defined as rdf:Property."@en ;
  ] ;
  sh:property [
    sh:path schema:domainIncludes ;
    sh:hasValue assertion:AssertionCredential ;
    sh:minCount 1 ;
    sh:message "Assertion object must have AssertionCredential in schema:domainIncludes."@en ;
  ] .
