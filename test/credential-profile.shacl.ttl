@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix tst: <https://w3id.org/axone/ontology/test/> .
@prefix schema: <http://schema.org/> .
@prefix prof: <https://w3id.org/axone/ontology/v$major/schema/core/profile/> .

tst:ProfileCredentialClassShape a sh:NodeShape ;
  sh:targetNode prof:ProfileCredential ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdfs:Class ;
    sh:minCount 1 ;
    sh:message "ProfileCredential must be defined as an rdfs:Class."@en ;
  ] ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:message "ProfileCredential must have at least one rdfs:label."@en ;
  ] ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:message "ProfileCredential must have at least one rdfs:comment describing its purpose."@en ;
  ] .

tst:ProfileCredentialStringPropertyShape a sh:NodeShape ;
  sh:targetNode prof:tag, schema:description, schema:name ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdf:Property ;
    sh:minCount 1 ;
    sh:message "Profile text properties must be defined as rdf:Property."@en ;
  ] ;
  sh:property [
    sh:path schema:domainIncludes ;
    sh:hasValue prof:ProfileCredential ;
    sh:minCount 1 ;
    sh:message "Profile text properties must have ProfileCredential in schema:domainIncludes."@en ;
  ] ;
  sh:property [
    sh:path schema:rangeIncludes ;
    sh:hasValue xsd:string ;
    sh:minCount 1 ;
    sh:message "Profile text properties must have xsd:string in schema:rangeIncludes."@en ;
  ] .

tst:ProfileCredentialUriPropertyShape a sh:NodeShape ;
  sh:targetNode prof:link, schema:image, schema:sameAs ;
  sh:property [
    sh:path rdf:type ;
    sh:hasValue rdf:Property ;
    sh:minCount 1 ;
    sh:message "Profile URI properties must be defined as rdf:Property."@en ;
  ] ;
  sh:property [
    sh:path schema:domainIncludes ;
    sh:hasValue prof:ProfileCredential ;
    sh:minCount 1 ;
    sh:message "Profile URI properties must have ProfileCredential in schema:domainIncludes."@en ;
  ] ;
  sh:property [
    sh:path schema:rangeIncludes ;
    sh:hasValue xsd:anyURI ;
    sh:minCount 1 ;
    sh:message "Profile URI properties must have xsd:anyURI in schema:rangeIncludes."@en ;
  ] .
